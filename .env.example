# MongoDB Database URI (Atlas or Local)
MONGODB_URI=mongodb://localhost:27017/python_playground

# WATI (WhatsApp Business API) Configs
# Set WATI_API_KEY=mock to run in mock/local mode where OTPs are logged to server stdout console
WATI_API_KEY=mock
WATI_BASE_URL=https://api.wati.io
WATI_OTP_TEMPLATE=otp_verification

# CRM Webhook URL
# Set CRM_WEBHOOK_URL=mock to run in mock mode
CRM_WEBHOOK_URL=mock

# Secrets for JWT Sessions
SESSION_SIGNING_KEY=change_this_to_a_long_random_string_for_user_sessions
ADMIN_SESSION_KEY=change_this_to_a_long_random_string_for_admin_sessions

# OTP Rules
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
